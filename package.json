{
  "name": "cc-mobile",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:server": "bun run server/index.ts",
    "dev:client": "bunx vite",
    "dev": "bun run dev:server & bun run dev:client",
    "serve": "./dev.sh",
    "generate:icons": "bun run scripts/generate-dev-icons.ts",
    "prebuild": "bun run generate:icons",
    "build": "bunx vite build",
    "start": "NODE_ENV=production bun run server/index.ts",
    "start:prod": "bun run build && bun run start",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "test": "bun test",
    "test:integration": "bun --config=/dev/null test --timeout=130000 ./server/integration/pty-live.e2e.test.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; git config core.hooksPath .githooks 2>/dev/null; true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.148",
    "node-pty": "1.1.0",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "ansi-to-react": "^6.2.6",
    "dompurify": "^3.3.3",
    "elysia": "^1.2.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.3",
    "mermaid": "^11.13.0",
    "morphdom": "^2.7.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view-lite": "^2.5.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@happy-dom/global-registrator": "^20.8.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/dompurify": "^3.2.0",
    "@types/morphdom": "^2.4.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
